# Supabase keys are committed in src/lib/config.ts so the app builds and runs
# on a static host (GitHub Pages) with no secrets. These env vars are OPTIONAL
# overrides — set them in .env.local only to point at a different project.
#
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key
#
# Sub-path the site is served from on GitHub Pages project sites
# (e.g. /Tiandy-store). The deploy workflow sets this automatically; leave it
# empty for local development.
# NEXT_PUBLIC_BASE_PATH=
